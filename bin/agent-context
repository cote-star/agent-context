#!/usr/bin/env python3
"""Thin shim so `bin/agent-context` works from a clone without `pip install .`.

The real CLI lives at `agent_context/cli.py` (importable module). This shim
prepends the repo root to sys.path so the module resolves, then delegates.
When the package is installed via `uv tool install` / `pip install`, the
console-script entry point declared in pyproject.toml is used instead and
this shim is bypassed.
"""

import pathlib
import sys

sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent.parent))

from agent_context.cli import main_cli  # noqa: E402

if __name__ == "__main__":
    sys.exit(main_cli())
