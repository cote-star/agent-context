# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
.pytest_cache/

# Python packaging build artifacts (sdist + wheel land in dist/; build/ is
# the setuptools temp tree).
/build/
/dist/

# Node
node_modules/

# macOS
.DS_Store

# Editors
.idea/
.vscode/
*.swp
*.swo

# Cross-agent coordination runtime (chorus-written, not part of the project)
.agent-chorus/

# Local pack state in host repos that vendor agent-context — do not track
# if someone clones this repo into another repo. The worked example's pack
# under examples/hello-service/.agent-context/ AND this repo's own
# self-applied pack at /.agent-context/current/ are intentionally tracked.
# /.agent-context/tools/ is NOT tracked because the canonical tools live at
# /tools/; the in-pack copies are runtime convenience only.
.agent-context/
!/.agent-context/
!/.agent-context/current/
!/.agent-context/current/**
/.agent-context/tools/
!examples/hello-service/.agent-context/
!examples/hello-service/.agent-context/**

# dotfiles like .env.example should still be tracked for the example
!examples/hello-service/.env.example

# Private/local artifacts (per-machine research, browser captures, etc.) — not
# part of the public product repo.
docs/experiments/
/experiments/
.playwright-mcp/
agent-context-rethink-title.png

# scripts/experiments/ is intentionally TRACKED — it holds the public,
# reproducible methodology (schema, extractors, lane runners, judges).
# Local-only artifacts inside it stay ignored:
scripts/experiments/__pycache__/
scripts/experiments/*.pyc
